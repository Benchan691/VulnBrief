{
  "mongodb": {
    "local_database": "web",
    "web_database": "web",
    "vulnerabilities_database": "vulnerabilities",
    "review_view_suffix": "_review"
  },
  "newsletter_root": "newsletters",
  "web_auth": {
    "bootstrap_username": "admin"
  },
  "tavily": {
    "search_depth": "basic",
    "max_results": 5,
    "request_timeout_seconds": 30,
    "max_concurrent_requests": 4
  },
  "enriched": {
    "llm_base_url": "http://100.102.169.17:8080/v1",
    "llm_model": "qwen3-4b-ipex",
    "llm_timeout_seconds": 300,
    "llm_connect_timeout_seconds": 300,
    "llm_max_output_tokens": 32768,
    "llm_evidence_max_output_tokens": 2048,
    "llm_report_max_output_tokens": 8192,
    "llm_connection_retries": 3,
    "llm_retry_wait_seconds": 5,
    "llm_page_chars": 12000,
    "llm_disable_thinking": true,
    "results_per_task": 4,
    "evidence_cache_enabled": true,
    "evidence_cache_version": "2",
    "vendor_domain_map": {}
  },
  "report": {
    "item_json_retries": 2,
    "final_json_retries": 2,
    "json_error_message": "The JSON above is invalid.\n\nError:\n${error}\n\nFix it and return only valid JSON. No Markdown, no explanation, no extra text. Keep the original fields and meaning. Make only the minimum changes needed so it can parse with `json.loads()`.",
    "deny_keys": [
      "raw",
      "raw_fields",
      "raw_sections",
      "raw_tables"
    ],
    "deny_prefixes": [
      "raw_"
    ],
    "max_depth": 10,
    "max_list_items": 100,
    "max_string_chars": 12000,
    "preview_after_each_item": true
  },
  "scheduler": {
    "scan_interval_seconds": 60
  }
}
