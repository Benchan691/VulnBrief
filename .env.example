# Secrets and connection strings only. Non-sensitive settings live in config/config.json.
# Environment variables override config.json when both are set.

# MongoDB URI for both web and vulnerabilities databases (same server, different DB names).
# MONGO_URI overrides LOCAL_MONGO_URI when both are set.
LOCAL_MONGO_URI=mongodb://localhost:27017/
# Docker Compose overrides LOCAL_MONGO_URI to host.docker.internal for web.
FLASK_SECRET_KEY=change-me

TAVILY_API_KEY=
TAVILY_API_KEYS=
EXA_API_KEYS=
