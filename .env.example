ATLAS_MONGO_URI=mongodb://atlas.example/
# Docker Compose overrides this to host.docker.internal for web and scheduler.
LOCAL_MONGO_URI=mongodb://localhost:27017/
FLASK_SECRET_KEY=change-me

WEB_DATABASE=web
LOCAL_DATABASE=web
VULNERABILITIES_DATABASE=vulnerabilities
AI_TASK_COLLECTION=ai_generation_tasks
AI_PROVIDER_METRICS_COLLECTION=ai_provider_metrics

RABBITMQ_URL=amqps://user:password@host/vhost
RABBITMQ_INTAKE_QUEUE=company_ai_preprocessing
RABBITMQ_COMPANY_QUEUE=company_ai_processing
RABBITMQ_GPU_QUEUE=gpu_processing
RABBITMQ_DEEPSEEK_QUEUE=deepseek_processing
RABBITMQ_GEMINI_QUEUE=gemini_processing
RABBITMQ_MAX_PRIORITY=10
RABBITMQ_MAX_QUEUE_SIZE=19999
RABBITMQ_BACKGROUND_PRIORITY=1
RABBITMQ_REPORT_PRIORITY=10

BACKGROUND_PREPROCESSING_ENABLED=false
COMPANY_AI_ENABLED=true
COMPANY_AI_BASE_URL=https://company-ai.example
COMPANY_AI_USERNAME=owner@example.com
COMPANY_AI_PASSWORD=change-me
COMPANY_AI_START_PROMPT=Prime this chat for vulnerability JSON.
COMPANY_AI_SUMMARY_PROMPT=Write the final cybersecurity report summary in ${language}.
COMPANY_AI_PUBLIC_KEY_B64=base64-public-key
COMPANY_AI_SIGN_SECRET=change-me
COMPANY_AI_MODEL=company-model
COMPANY_AI_PARALLEL_CHATS=4
COMPANY_AI_DEFAULT_EWMA_SECONDS=60

DEEPSEEK_ENABLED=false
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=
DEEPSEEK_TIMEOUT_SECONDS=180
DEEPSEEK_MAX_OUTPUT_TOKENS=4096
DEEPSEEK_JSON_RETRIES=1
DEEPSEEK_WORKER_CONCURRENCY=1
DEEPSEEK_DEFAULT_EWMA_SECONDS=45

GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=
GEMINI_TIMEOUT_SECONDS=180
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_JSON_RETRIES=1
GEMINI_WORKER_CONCURRENCY=1
GEMINI_DEFAULT_EWMA_SECONDS=50

GPU_ENABLED=false
GPU_QUEUE_BACKLOG_LIMIT=20
GPU_WORKER_CONCURRENCY=1
GPU_DEFAULT_EWMA_SECONDS=30

PREPROCESSING_CACHE_VERSION=1
REPORT_MAX_DEPTH=10
REPORT_ITEM_JSON_RETRIES=2
REPORT_FINAL_JSON_RETRIES=2
REPORT_PREVIEW_AFTER_EACH_ITEM=true
