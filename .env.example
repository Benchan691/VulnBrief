# Copy to .env or export these variables. config/config.json remains required;
# any variable set here overrides the matching JSON value.

APP_CONFIG=config/config.json
MONGO_URI=mongodb://localhost:27017/
WEB_DATABASE=web
VULNERABILITIES_DATABASE=vulnerabilities
REVIEW_VIEW_SUFFIX=_review
FLASK_SECRET_KEY=change-me
NEWSLETTER_ROOT=newsletters
SOURCES_CONFIG=config/sources.json

COMPANY_AI_BASE_URL=https://smartoa.china-entercom.com
COMPANY_AI_USERNAME=replace-with-username
COMPANY_AI_PASSWORD=replace-with-rotated-password
COMPANY_AI_START_PROMPT=
COMPANY_AI_SUMMARY_PROMPT=
COMPANY_AI_PUBLIC_KEY_B64=
COMPANY_AI_SIGN_SECRET=
COMPANY_AI_API_TIMEZONE=Asia/Shanghai
COMPANY_AI_SSE_DELAY_SECONDS=2
COMPANY_AI_MODEL=qwen3.5-35b-a3b-gptq
COMPANY_AI_OWNER_ACCOUNT=replace-with-owner-account
COMPANY_AI_PLATFORM_ID=5
COMPANY_AI_QA_TYPE=0
COMPANY_AI_FROM_SOURCE=normal_chat
COMPANY_AI_USE_THINK=true
COMPANY_AI_USER_PROMPT=
COMPANY_AI_DATASET_IDS=[]
COMPANY_AI_FILE_IDS=[]
COMPANY_AI_CONTEXT_LIMIT=32768
COMPANY_AI_MAX_OUTPUT_TOKENS=4096
COMPANY_AI_TIMEOUT_SECONDS=180
COMPANY_AI_RETRIES=1
COMPANY_AI_PARALLEL_CHATS=4

RABBITMQ_URL=amqps://user:password@host.lmq.cloudamqp.com/vhost
RABBITMQ_QUEUE_NAME=company_ai_preprocessing
RABBITMQ_MAX_PRIORITY=10
RABBITMQ_BACKGROUND_PRIORITY=1
RABBITMQ_REPORT_PRIORITY=10

COMPANY_AI_SCAN_INTERVAL_SECONDS=60
COMPANY_AI_STALE_PROCESSING_SECONDS=900
COMPANY_AI_REPORT_WAIT_TIMEOUT_SECONDS=300
COMPANY_AI_MAX_TASK_ATTEMPTS=10

REPORT_ITEM_JSON_RETRIES=2
REPORT_FINAL_JSON_RETRIES=2
REPORT_JSON_ERROR_MESSAGE=The JSON above is invalid. Error: ${error} Fix it and return only valid JSON.
REPORT_DENY_KEYS=["raw","raw_fields","raw_sections","raw_tables"]
REPORT_DENY_PREFIXES=["raw_"]
REPORT_MAX_DEPTH=6
REPORT_MAX_LIST_ITEMS=100
REPORT_MAX_STRING_CHARS=12000
REPORT_PREVIEW_AFTER_EACH_ITEM=true
