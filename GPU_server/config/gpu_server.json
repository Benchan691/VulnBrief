{
  "inference": {
    "instance_count": 1,
    "worker_concurrency": 1,
    "tensor_split": "1,1,1",
    "model_path": "/models/Qwen3_Qwen3_30B-A3B-Instruct-2507_Q4_K_M.gguf",
    "model_name": "qwen-local",
    "context_size": 4096,
    "base_url": "http://127.0.0.1:8080/v1",
    "docker_base_url": "http://host.docker.internal:8080/v1",
    "base_port": 8080,
    "auto_start_llama_servers": true,
    "startup_wait_seconds": 600,
    "startup_poll_seconds": 5,
    "request_timeout_seconds": 300,
    "json_retries": 2,
    "max_output_tokens": 4096,
    "llama_log_verbosity": 1,
    "log_messages": true,
    "log_message_chars": 2000
  },
  "rabbitmq": {
    "gpu_queue": "gpu_processing",
    "company_queue": "company_ai_processing",
    "max_priority": 10,
    "background_priority": 1,
    "max_queue_size": 19999
  },
  "mongodb": {
    "vulnerabilities_database": "vulnerabilities",
    "ai_task_collection": "ai_generation_tasks"
  },
  "processing": {
    "cache_version": "1",
    "stale_processing_seconds": 900,
    "max_task_attempts": 2
  },
  "prompts": {
    "start_prompt": "You are a professional Cyber Threat Intelligence and Vulnerability Report Writer. Use only the JSON data provided.\n",
    "final_summary_prompt": "Write the overall cybersecurity report executive summary in ${language}. Return valid JSON only with executive_summary, trends, and recommendations."
  },
  "report_compaction": {
    "deny_keys": ["raw", "raw_fields", "raw_sections", "raw_tables"],
    "deny_prefixes": ["raw_"],
    "max_depth": 10,
    "max_list_items": 100,
    "max_string_chars": 12000
  },
  "flags": {
    "gpu_enabled": true,
    "company_ai_enabled": true
  }
}
