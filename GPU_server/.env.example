ATLAS_MONGO_URI=mongodb+srv://user:password@atlas.example/
VULNERABILITIES_DATABASE=vulnerabilities
AI_TASK_COLLECTION=ai_generation_tasks
RABBITMQ_URL=amqps://user:password@host.lmq.cloudamqp.com/vhost
RABBITMQ_GPU_QUEUE=gpu_processing
RABBITMQ_COMPANY_QUEUE=company_ai_processing
RABBITMQ_MAX_PRIORITY=10
RABBITMQ_BACKGROUND_PRIORITY=1
GPU_ENABLED=true
COMPANY_AI_ENABLED=true

# Per-GPU mode: one llama-server per GPU (docker compose --profile per-gpu up -d)
GPU_INSTANCE_COUNT=3
# Optional explicit URLs instead of llama-server-{n} defaults:
# GPU_INFERENCE_BASE_URLS=http://llama-server-0:8080/v1,http://llama-server-1:8080/v1,http://llama-server-2:8080/v1
# GPU_WORKER_CONCURRENCY defaults to GPU_INSTANCE_COUNT in per-GPU mode

# Tensor-split mode: one model across GPUs (docker compose --profile tensor-split up -d)
# GPU_INSTANCE_COUNT=1
# GPU_TENSOR_SPLIT=1,1,1
# GPU_WORKER_CONCURRENCY=1

GPU_MODEL_PATH=/models/your-model.gguf
GPU_MODEL_NAME=qwen-local
GPU_CONTEXT_SIZE=4096
GPU_TENSOR_SPLIT=1,1,1
GPU_WORKER_CONCURRENCY=3
GPU_MAX_TASK_ATTEMPTS=2
GPU_REQUEST_TIMEOUT_SECONDS=300
GPU_JSON_RETRIES=2
GPU_MAX_OUTPUT_TOKENS=4096
GPU_START_PROMPT="You are a professional Cyber Threat Intelligence and Vulnerability Report Writer. Use only the JSON data provided.\n"
GPU_FINAL_SUMMARY_PROMPT="Write the overall cybersecurity report executive summary in ${language}. Return valid JSON only with executive_summary, trends, and recommendations."

PREPROCESSING_CACHE_VERSION=1
COMPANY_AI_STALE_PROCESSING_SECONDS=900
REPORT_DENY_KEYS=["raw","raw_fields","raw_sections","raw_tables"]
REPORT_DENY_PREFIXES=["raw_"]
REPORT_MAX_DEPTH=6
REPORT_MAX_LIST_ITEMS=100
REPORT_MAX_STRING_CHARS=12000
